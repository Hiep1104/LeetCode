class Solution(object):
    def isPalindrome(self, x):
        """
        :type x: int
        :rtype: bool
        """
        l=list()
        if x<0:
            return False
        else:
            while x>0:
                a= x%10
                x=x//10
                l.append(a)
            l2=l[::-1]
            if l==l2:
                return True
            else:
                return False
